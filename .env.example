# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk (legacy; remove after custom auth migration)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Custom auth — required when USE_LEGACY_CLERK=false (openssl rand -base64 32).
# Also used to encrypt TOTP secrets at rest (Wave 4 2FA).
AUTH_SECRET=
# When false, ClerkProvider is omitted from the root layout — app shell must use custom session only (Wave 5+).
USE_LEGACY_CLERK=true
# Optional: FEATURE_PASSWORD_LOGIN=true|false (overrides app_config in DB)

# Resend (email verification & password reset)
RESEND_API_KEY=
RESEND_FROM=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OAuth — Google (PKCE; set redirect URI to {NEXT_PUBLIC_APP_URL}/api/auth/callback/google in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=  # optional override; defaults to {NEXT_PUBLIC_APP_URL}/api/auth/callback/google
