# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App session signing + TOTP secret encryption (openssl rand -base64 32)
AUTH_SECRET=

# Resend (email verification & password reset)
RESEND_API_KEY=
RESEND_FROM=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OAuth — Google (PKCE; set redirect URI to {NEXT_PUBLIC_APP_URL}/api/auth/callback/google in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=  # optional override; defaults to {NEXT_PUBLIC_APP_URL}/api/auth/callback/google

# Level generation (OpenRouter)
OPENROUTER_API_KEY=
LEVEL_GEN_MODEL=anthropic/claude-sonnet-4.5
